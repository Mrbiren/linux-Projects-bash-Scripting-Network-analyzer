Html 
<!DOCTYPE html>
<html>
<head>
<title>Simple dApp</title>
<script src="https://cdn.jsdelivr.net/npm/web3@4.0.3/dist/web3.min.js"></script>
</head>
<body>
<h2>Message dApp</h2>
<button onclick="connect()">Connect MetaMask</button>
<br><br>
<button onclick="readMessage()">Read Message</button>
<p id="msg"></p>
<input type="text" id="newmsg" placeholder="Enter new message">
<button onclick="updateMessage()">Update Message</button>
<script>
let web3;
let contract;
const contractAddress = "0xc8c8C51ACF0a191b2750b09830b3FffD67f03711";
const abi = [];
async function connect(){
web3 = new Web3(window.ethereum);
await window.ethereum.request({method:"eth_requestAccounts"});
contract = new web3.eth.Contract(abi, contractAddress);
alert("Wallet Connected");
}
async function readMessage(){
const message = await contract.methods.message().call();
document.getElementById("msg").innerText = message;
}
async function updateMessage(){
const accounts = await web3.eth.getAccounts();
const newMessage = document.getElementById("newmsg").value;
await contract.methods.setMessage(newMessage).send({
from: accounts[0]
});
alert("Message Updated");
}
</script>
</body>
</html>

