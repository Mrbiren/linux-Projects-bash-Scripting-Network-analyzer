text = """Information Retrieval is used in search engines.
Search engines help users find information quickly.
Text summarization reduces long text into short form.
It saves time and improves efficiency."""

sentences = text.split(".")

freq = {}
for word in text.lower().split():
    freq[word] = freq.get(word, 0) + 1

scores = {}
for sent in sentences:
    for word in sent.lower().split():
        if word in freq:
            scores[sent] = scores.get(sent, 0) + freq[word]
top_sentences = sorted(scores, key=scores.get, reverse=True)[:2]

print("Summary:")
for s in top_sentences:
    print(s.strip())

