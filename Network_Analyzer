package excelwrite;

import jxl.Workbook;
import jxl.WorkbookSettings;
import jxl.write.Label;
import jxl.write.WritableSheet;
import jxl.write.WritableWorkbook;

import java.io.File;
import java.util.Locale;

public class ExcelWrite {

    public static void main(String[] args) throws Exception {

        String header[] = {"Student Name", "Subject1", "Subject2", "Subject3", "Total"};
        String sname[] = {"Vijaya", "Birendra", "Maithili", "Diya"};
        int marks[] = {50, 45, 60, 55};

        WorkbookSettings ws = new WorkbookSettings();
        ws.setLocale(new Locale("en", "EN"));

        WritableWorkbook workbook = Workbook.createWorkbook(new File("student.xls"), ws);
        WritableSheet sheet = workbook.createSheet("Report", 0);

        for (int c = 0; c < header.length; c++) {
            sheet.addCell(new Label(c, 0, header[c]));
        }
        for (int r = 0; r < sname.length; r++) {

            sheet.addCell(new Label(0, r + 1, sname[r]));

            for (int c = 1; c <= 3; c++) {
                sheet.addCell(new jxl.write.Number(c, r + 1, marks[r])); 
            }

            int total = marks[r] * 3;
            sheet.addCell(new jxl.write.Number(4, r + 1, total)); 
        }

        workbook.write();
        workbook.close();

        System.out.println("Excel File Created!");
    }
}




