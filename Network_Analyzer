    if all(word in text.split() for word in query):
        print("Match:", id ,":", text)

N = len(docs)

for id, text in docs.items():
    score = 0
    words = text.split()

    for q in query:
        tf = words.count(q)
        df = sum(q in d.split() for d in docs.values())
        if df != 0:
            idf = math.log(N / df)
            score += tf * idf

    print("Doc", id, "Score:", round(score,2))



