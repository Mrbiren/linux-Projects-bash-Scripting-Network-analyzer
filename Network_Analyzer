const { Web3 } = require("web3");
const web3 = new Web3("http://127.0.0.1:7545");

const contractAddress = " 0xC95eb015826053C02a6Ad859DE7c599e85872651";
const abi = [];
const contract = new web3.eth.Contract(abi, contractAddress);
async function readEvents(){
console.log("Reading events...");
const events = await contract.getPastEvents("ActionPerformed", {
    fromBlock: 0,
    toBlock: "latest"
});

events.forEach(e => {
console.log("Event Received!");
console.log("User:", e.returnValues.user);
console.log("Action:", e.returnValues.action);
});
}
