from sklearn import svm
import numpy as np

X = np.array([
    [3, 1],
    [2, 2],
    [1, 3],
    [2, 1]
])

y = np.array([3, 2, 1, 2])

X_pair = []
y_pair = []

for i in range(len(X)):
    for j in range(len(X)):
        if y[i] > y[j]:
            X_pair.append(X[i] - X[j])
            y_pair.append(1)
        elif y[i] < y[j]:
            X_pair.append(X[i] - X[j])
            y_pair.append(-1) 

X_pair = np.array(X_pair)
y_pair = np.array(y_pair)

model = svm.LinearSVC()
model.fit(X_pair, y_pair)

scores = model.decision_function(X)

print("Scores:")
for i, s in enumerate(scores):
    print(f"Doc {i+1}: {round(s,2)}")

ranking = np.argsort(-scores)

print("\nRanking:")
for i in ranking:
    print(f"Doc {i+1}")



