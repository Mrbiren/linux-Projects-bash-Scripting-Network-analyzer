import pandas as pd
import plotly.express as px

df = pd.DataFrame({
    "Date": pd.date_range("2024-01-01", periods=10),
    "Region": ["East","West","North","South"] * 2 + ["East","West"],
    "Product": ["Laptop","Mobile","Tablet"] * 3 + ["Laptop"],
    "Sales": [50000,30000,20000,45000,32000,22000,48000,35000,21000,53000],
    "Profit": [12000,8000,5000,10000,8500,5200,11000,9000,5100,13000]
})

px.bar(df, x="Region", y="Sales", color="Region", title="Sales by Region").show()
px.line(df, x="Date", y="Sales", markers=True, title="Sales Trend").show()
px.pie(df, names="Product", values="Profit", title="Profit by Product").show()


B)
import plotly.graph_objects as go

total_sales = df["Sales"].sum()
total_profit = df["Profit"].sum()

go.Figure(go.Indicator(
    mode="number",
    value=total_sales,
    title={"text": "Total Sales"}
)).show()

filtered_df = df[df["Region"] == "East"]

px.bar(filtered_df, x="Product", y="Sales", title="East Region Sales").show()


C)
