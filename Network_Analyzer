def edit_distance(a, b):
    dp = [[0]*(len(b)+1) for _ in range(len(a)+1)]

    for i in range(len(a)+1):
        dp[i][0] = i
    for j in range(len(b)+1):
        dp[0][j] = j

    for i in range(1, len(a)+1):
for j in range(1, len(b)+1):
            if a[i-1] == b[j-1]:
                cost = 0
            else:
                cost = 1

            dp[i][j] = min(
                dp[i-1][j] + 1,
                dp[i][j-1] + 1,
                dp[i-1][j-1] + cost
            )

    return dp[len(a)][len(b)]

vocab = set()

for text in docs.values():
    for word in text.split():
        vocab.add(word)

query = input("Enter search word: ").lower()

best_word = None
min_dist = 999

for word in vocab:
    d = edit_distance(query, word)
    if d < min_dist:

        min_dist = d
        best_word = word

print("Corrected word:", best_word)

print("\nDocuments found:")

for doc_id, text in docs.items():
    if best_word in text:
        print("Doc", doc_id, ":", text)


