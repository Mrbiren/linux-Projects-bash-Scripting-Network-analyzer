import math
docs = {
    1: "information retrieval system",
    2: "machine learning and information retrieval",
    3: "search engine uses retrieval model",
    4: "machine learning improves search engine"
}

doc_words = {i: text.split() for i, text in docs.items()}

query = input("Enter search query: ").lower().split()

print("\nBoolean Model Result:")

for doc_id, words in doc_words.items():
    if all(word in words for word in query):
        print("Doc", doc_id, ":", docs[doc_id])

vocab = set(word for words in doc_words.values() for word in words)

N = len(docs)
idf = {}

for term in vocab:
    df = sum(term in words for words in doc_words.values())
    idf[term] = math.log(N / df)

print("\nVector Space Model Ranking:")

for doc_id, words in doc_words.items():

    score = 0

    for term in query:
        tf = words.count(term)
        score += tf * idf.get(term, 0)

    print("Doc", doc_id, "Score:", round(score,2), "-", docs[doc_id])



