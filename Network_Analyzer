package com.testing;

import org.openqa.selenium.*;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.*;
import org.junit.Assert;

public class test {

	public static void main(String[] args) {

        System.setProperty("webdriver.chrome.driver","D:\\Download\\chrome-win64\\chrome-win64\\chrome.exe");

        WebDriver driver = new ChromeDriver();
        driver.manage().window().maximize();

        driver.get("https://practice.gabrains.com/");

        WebDriverWait wait = new WebDriverWait(driver, 10);

        WebElement emailField = wait.until(
                ExpectedConditions.visibilityOfElementLocated(By.name("email")));

        WebElement passwordField = driver.findElement(By.name("password"));
        emailField.sendKeys("qa_testers@gabrains.com");
        passwordField.sendKeys("Password123");

        WebElement loginBtn = driver.findElement(
                By.xpath("//button[contains(text(),'Login')]"));
        loginBtn.click();

        WebElement logoutBtn = wait.until(
                ExpectedConditions.visibilityOfElementLocated(
                        By.xpath("//*[contains(text(),'Logout')]")));

        Assert.assertTrue("Logout button not displayed - Login might have failed!",
                logoutBtn.isDisplayed());

        System.out.println("Login successful - Test Passed!");

        driver.quit();
		
		
	}

}


