px.scatter(df, x="Sales", y="Profit", color="Product",
           title="Sales vs Profit").show()

top_region = region_summary.loc[region_summary["Sales"].idxmax(), "Region"]
top_product = product_summary.loc[product_summary["Profit"].idxmax(), "Product"]

print("Top Performing Region:", top_region)
print("Most Profitable Product:", top_product)

if top_product == "Laptop":
    print("Recommendation: Increase Laptop promotions.")
else:
    print("Recommendation: Focus on high-profit products.")





